---
import type { Category } from "@/lib/categories";

type Entry = {
  slug: string;
  title: string;
  summary: string;
  category: Category;
  updated_at: string;
  view_count: number;
};

const { entry } = Astro.props as { entry: Entry };
---

<article class="panel h-full p-5 transition hover:-translate-y-0.5 hover:border-[color:var(--color-gold)]">
  <div class="flex items-center justify-between gap-4 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[color:var(--color-moss)]">
    <span>{entry.category}</span>
    <span>{new Date(entry.updated_at).toLocaleDateString()}</span>
  </div>
  <h3 class="mt-4 text-2xl text-[color:var(--color-ink)]">
    <a href={`/wiki/${entry.slug}`}>{entry.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">{entry.summary}</p>
  <div class="mt-5 text-xs font-semibold uppercase tracking-[0.24em] text-[color:var(--color-gold)]">
    {entry.view_count} views
  </div>
</article>
