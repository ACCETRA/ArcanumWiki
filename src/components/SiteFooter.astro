---
import { absoluteUrl, siteConfig } from "@/lib/site";

const links = [
  { href: "/wiki", label: "Browse the archive" },
  { href: "/guides", label: "Read the guides" },
  { href: "/resources", label: "Open the tools" },
  { href: "/search", label: "Search the site" },
];
---

<footer class="site-footer">
  <div>
    <div class="kicker">Public pages first</div>
    <h2>Readable lore, credited authorship, and browser-side tools.</h2>
    <p>
      {siteConfig.name} stays focused on practical fantasy reference pages that load fast and remain useful without a login wall.
    </p>
  </div>

  <nav class="site-footerLinks" aria-label="Footer navigation">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </nav>

  <div class="site-footerMeta">
    <span>{absoluteUrl("/")}</span>
    <span>Handmade archive, static-first launch.</span>
  </div>
</footer>
