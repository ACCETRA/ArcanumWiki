---
type GuideCardData = {
  id: string;
  data: {
    title: string;
    description: string;
    publishedAt: Date;
    author: string;
    tags: string[];
  };
};

const { guide } = Astro.props as { guide: GuideCardData };
---

<article class="panel h-full p-5 transition hover:-translate-y-0.5 hover:border-[color:var(--color-gold)]">
  <div class="flex flex-wrap items-center gap-2 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[color:var(--color-moss)]">
    <span>{guide.data.author}</span>
    <span>{guide.data.publishedAt.toLocaleDateString()}</span>
  </div>
  <h3 class="mt-4 text-2xl text-[color:var(--color-ink)]">
    <a href={`/guides/${guide.id}`}>{guide.data.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">{guide.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {guide.data.tags.slice(0, 3).map((tag) => (
      <span class="rounded-full bg-[color:var(--color-paper-strong)] px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[color:var(--color-clay)]">
        {tag}
      </span>
    ))}
  </div>
</article>
