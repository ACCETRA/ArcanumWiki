---
import { siteConfig } from "@/lib/site";

const nav = [
  { href: "/wiki", label: "Archive" },
  { href: "/guides", label: "Guides" },
  { href: "/campaigns", label: "Campaigns" },
  { href: "/resources", label: "Tools" },
  { href: "/search", label: "Search" },
  { href: "/contributors", label: "Scribes" },
  { href: "/about", label: "About" },
];
---

<header class="site-header">
  <a class="site-brand" href="/" aria-label="ArcanumWiki home">
    <span class="site-mark" aria-hidden="true"><span></span></span>
    <span>
      <strong>ArcanumWiki</strong>
      <small>{siteConfig.tagline}</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    {nav.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
    <a class="site-support" href={siteConfig.donateUrl} rel="noreferrer" target="_blank">
      Support
    </a>
  </nav>
</header>
