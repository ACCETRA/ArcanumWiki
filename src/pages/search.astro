---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getArchiveEntries } from "@/lib/archive";

const guides = await getCollection("guides");
const searchIndex = JSON.stringify([
  ...getArchiveEntries().map((entry) => ({
    title: entry.title,
    summary: entry.summary,
    url: `/wiki/${entry.slug}`,
    type: entry.category,
    text: `${entry.title} ${entry.summary} ${entry.category} ${entry.content}`,
  })),
  ...guides.map((guide) => ({
    title: guide.data.title,
    summary: guide.data.description,
    url: `/guides/${guide.id}`,
    type: "Guide",
    text: `${guide.data.title} ${guide.data.description} ${guide.data.author} ${guide.data.tags.join(" ")}`,
  })),
]);
---

<BaseLayout
  title="Search"
  description="Search the ArcanumWiki build with Pagefind static search."
  path="/search"
>
  <section class="shell py-12">
    <div class="max-w-4xl">
      <div class="eyebrow">Static search</div>
      <h1 class="mt-5 text-5xl text-[color:var(--color-ink)] md:text-6xl">Search the archive, guides, and public tools.</h1>
      <p class="mt-5 text-lg leading-8 text-[color:var(--color-ink-soft)]">
        Production builds use Pagefind. Local development uses the same curated archive and guide data directly, so search stays usable everywhere.
      </p>
    </div>

    <div class="panel mt-8 p-6">
      <div id="search"></div>
    </div>
  </section>

  <script is:inline id="local-search-data" type="application/json" set:html={searchIndex}></script>

  <script is:inline type="module">
    const mount = document.querySelector("#search");
    const dataScript = document.querySelector("#local-search-data");
    const localItems = JSON.parse(dataScript?.textContent || "[]");

    const normalize = (value) => value.toLowerCase().trim();

    function resultScore(item, query) {
      const q = normalize(query);
      if (!q) return 0;
      const title = normalize(item.title);
      const type = normalize(item.type);
      const text = normalize(item.text);
      if (title === q) return 100;
      if (title.includes(q)) return 80;
      if (type.includes(q)) return 60;
      if (text.includes(q)) return 35;
      return 0;
    }

    const renderFallback = () => {
      if (!mount) return;

      const wrapper = document.createElement("div");
      wrapper.className = "local-search";

      const label = document.createElement("label");
      label.className = "local-search-label";
      label.htmlFor = "local-search-input";
      label.textContent = "Search query";

      const input = document.createElement("input");
      input.id = "local-search-input";
      input.type = "search";
      input.autocomplete = "off";

      const summary = document.createElement("p");
      summary.className = "local-search-summary";

      const results = document.createElement("div");
      results.className = "local-search-results";

      wrapper.append(label, input, summary, results);
      mount.replaceChildren(wrapper);

      const renderResults = () => {
        const query = input.value;
        const matches = localItems
          .map((item) => ({ item, score: resultScore(item, query) }))
          .filter((row) => row.score > 0)
          .sort((a, b) => b.score - a.score || a.item.title.localeCompare(b.item.title))
          .slice(0, 12);

        results.replaceChildren();

        if (!query.trim()) {
          summary.textContent = `${localItems.length} pages and guides are available to search.`;
          return;
        }

        summary.textContent = matches.length
          ? `${matches.length} result${matches.length === 1 ? "" : "s"} for "${query}".`
          : `No results for "${query}".`;

        for (const { item } of matches) {
          const link = document.createElement("a");
          link.className = "local-search-result";
          link.href = item.url;

          const meta = document.createElement("span");
          meta.textContent = item.type;

          const title = document.createElement("strong");
          title.textContent = item.title;

          const text = document.createElement("p");
          text.textContent = item.summary;

          link.append(meta, title, text);
          results.append(link);
        }
      };

      input.addEventListener("input", renderResults);
      renderResults();
      input.focus();
    };

    try {
      const mod = await import("/pagefind/pagefind-ui.js");
      new mod.default({
        element: "#search",
        showSubResults: true,
        excerptLength: 18,
        resetStyles: false,
      });
    } catch {
      renderFallback();
    }
  </script>

  <style>
    .local-search {
      display: grid;
      gap: 1rem;
    }

    .local-search-label {
      color: var(--color-gold);
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .local-search input {
      width: 100%;
      border: 1px solid var(--color-line);
      border-radius: 0.375rem;
      background: rgba(34, 41, 31, 0.72);
      color: var(--color-ink);
      font: inherit;
      font-size: 1rem;
      padding: 0.9rem 1rem;
      outline: none;
    }

    .local-search input:focus {
      border-color: rgba(220, 187, 123, 0.56);
    }

    .local-search-summary {
      color: var(--color-ink-soft);
      font-size: 0.95rem;
    }

    .local-search-results {
      display: grid;
      gap: 0.75rem;
    }

    .local-search-result {
      display: grid;
      gap: 0.45rem;
      border: 1px solid var(--color-line);
      border-radius: 0.375rem;
      background: rgba(255, 255, 255, 0.03);
      padding: 1rem;
      transition: border-color 180ms ease, transform 180ms ease;
    }

    .local-search-result:hover {
      border-color: rgba(220, 187, 123, 0.48);
      transform: translateY(-1px);
    }

    .local-search-result span {
      color: var(--color-gold);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .local-search-result strong {
      color: var(--color-ink);
      font-family: var(--font-display);
      font-size: 1.35rem;
    }

    .local-search-result p {
      margin: 0;
      color: var(--color-ink-soft);
      line-height: 1.6;
    }
  </style>
</BaseLayout>
