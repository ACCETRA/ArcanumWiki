---
import ArchiveCard from "@/components/ArchiveCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryGroups } from "@/lib/archive";
import { CATEGORY_META, slugify } from "@/lib/categories";

const groups = getCategoryGroups();
---

<BaseLayout
  title="Archive"
  description="Browse the static ArcanumWiki archive by category and open public D&D reference pages."
  path="/wiki"
>
  <section class="shell py-12">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <div class="eyebrow">Public archive</div>
        <h1 class="mt-5 text-5xl text-[color:var(--color-ink)] md:text-6xl">Browse the shelves like a working reference room.</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[color:var(--color-ink-soft)]">
          Every page below is static, indexable, and readable without an account. Search lives at <a class="font-semibold text-[color:var(--color-gold)]" href="/search">/search</a>, while the archive page keeps the category structure visible for people who prefer to browse.
        </p>
      </div>

      <div class="panel p-6">
        <div class="kicker">Quick jumps</div>
        <div class="mt-4 flex flex-wrap gap-2">
          {groups.map((group) => (
            <a href={`#${slugify(group.category)}`} class="rounded-full bg-[color:var(--color-paper-strong)] px-4 py-2 text-sm font-semibold text-[color:var(--color-clay)] transition hover:bg-[color:var(--color-gold)] hover:text-white">
              {group.category}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {groups.map((group) => (
    <section class="shell py-6" id={slugify(group.category)}>
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <div class="kicker">{group.category}</div>
          <h2 class="mt-2 text-3xl text-[color:var(--color-ink)]">{CATEGORY_META[group.category].tagline}</h2>
          <p class="mt-3 max-w-3xl text-base leading-8 text-[color:var(--color-ink-soft)]">{CATEGORY_META[group.category].description}</p>
        </div>
      </div>
      <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {group.entries.map((entry) => (
          <ArchiveCard entry={entry} />
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
