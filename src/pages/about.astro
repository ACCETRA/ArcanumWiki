---
import BaseLayout from "@/layouts/BaseLayout.astro";

const principles = [
  "Public HTML remains the primary reading surface.",
  "Human-authored notes remain the editorial standard.",
  "No ads interrupting the reading experience.",
  "Generators that run in the browser from curated source data.",
  "Supabase helpers are isolated behind environment-gated server utilities.",
];
---

<BaseLayout
  title="About"
  description="ArcanumWiki is a human-made D&D toolkit built around static public pages, client-side tools, search, and clear authorship."
  path="/about"
>
  <section class="shell py-12">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr]">
      <div>
        <div class="eyebrow">What ArcanumWiki is for</div>
        <h1 class="mt-5 text-5xl text-[color:var(--color-ink)] md:text-6xl">A handmade D&D reference that chooses clarity over platform bloat.</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[color:var(--color-ink-soft)]">
          The public site is built around readable pages, practical guides, useful generators, search, and clear authorship. The archive stays static-first, while integration code is kept behind explicit environment checks so public reading never depends on a private dashboard.
        </p>
      </div>

      <div class="panel p-6">
        <div class="kicker">Operating rules</div>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">
          {principles.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
