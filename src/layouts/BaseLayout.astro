---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import "@/styles.css";
import { absoluteUrl, siteConfig } from "@/lib/site";

type Props = {
  title?: string;
  description?: string;
  path?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
};

const {
  title = siteConfig.name,
  description = siteConfig.description,
  path = "/",
  hideHeader = false,
  hideFooter = false,
} = Astro.props;

const canonical = absoluteUrl(path);
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#11160f" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/brand-logo.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:image" content={absoluteUrl("/brand-logo.png")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteUrl("/brand-logo.png")} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} Guides`} href="/rss.xml" />
    <slot name="head" />
  </head>
  <body>
    {hideHeader && hideFooter ? (
      <slot />
    ) : (
      <div class="template-site">
        <div class="template-frame">
          {!hideHeader && <SiteHeader />}
          <main class="template-main">
            <slot />
          </main>
          {!hideFooter && <SiteFooter />}
        </div>
      </div>
    )}
  </body>
</html>
