---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import "@/styles.css";
import { absoluteUrl, siteConfig } from "@/lib/site";

type Props = {
  title?: string;
  description?: string;
  path?: string;
};

const {
  title = siteConfig.name,
  description = siteConfig.description,
  path = "/",
} = Astro.props;

const canonical = absoluteUrl(path);
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4ecdc" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/brand-logo.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <slot name="head" />
  </head>
  <body>
    <div class="relative overflow-hidden">
      <div class="absolute inset-x-0 top-0 -z-10 h-[38rem] bg-[radial-gradient(circle_at_top,rgba(184,137,46,0.18),transparent_50%)]"></div>
      <div class="absolute inset-x-0 bottom-0 -z-10 h-[30rem] bg-[radial-gradient(circle_at_bottom_right,rgba(53,84,72,0.18),transparent_45%)]"></div>
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
